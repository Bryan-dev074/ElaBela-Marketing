# ---- Supabase (public, safe for the browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ---- Supabase service key (SERVER ONLY — never expose to the browser) ----
# Used by scripts/provision-users.mjs and any server-side admin action.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Domain suffix used to turn usernames into Supabase auth emails
# (e.g. "bryan" -> "bryan@elabela.app"). Change only if you re-provision users.
NEXT_PUBLIC_LOGIN_EMAIL_DOMAIN=elabela.app
